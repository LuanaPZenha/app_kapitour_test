REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET=kapitour-dev-secret-change-in-production
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Rate limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_FORGOT_PASSWORD=3/minute
RATE_LIMIT_REFRESH=10/minute
RATE_LIMIT_CHECKIN=30/minute
RATE_LIMIT_RESGATE_CUPOM=10/minute

# API — em dev o app detecta tudo sozinho (Metro + proxy). Mantenha localhost aqui.
EXPO_PUBLIC_API_URL=http://localhost:8000/api

# PostgreSQL (profile: docker compose --profile postgres up)
POSTGRES_PASSWORD=kapitour
USAR_ALEMBIC=false
# AUTH_DATABASE_URL=postgresql+psycopg2://kapitour:kapitour@postgres:5432/kapitour_auth
# CONTENT_DATABASE_URL=postgresql+psycopg2://kapitour:kapitour@postgres:5432/kapitour_content
# ENGAGEMENT_DATABASE_URL=postgresql+psycopg2://kapitour:kapitour@postgres:5432/kapitour_engagement
# COMMERCE_DATABASE_URL=postgresql+psycopg2://kapitour:kapitour@postgres:5432/kapitour_commerce
# KAPIPASS_DATABASE_URL=postgresql+psycopg2://kapitour:kapitour@postgres:5432/kapitour_kapipass

# SMTP (produção)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@kapitour.com
